{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "payment.approved.v1",
  "title": "payment.approved",
  "description": "결제 승인 완료를 알리는 이벤트.",
  "type": "object",
  "required": ["meta", "payload"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "allOf": [
        {
          "$ref": "../common/event-meta.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "eventType": {
              "const": "PaymentApprovedEvent",
              "description": "이 이벤트의 고정 타입명"
            }
          }
        }
      ]
    },
    "payload": {
      "type": "object",
      "description": "비즈니스 데이터",
      "required": ["paymentId", "orderId", "customerId", "amount", "currency", "approvedAt"],
      "additionalProperties": false,
      "properties": {
        "paymentId": {
          "type": "string",
          "description": "결제 ID"
        },
        "orderId": {
          "type": "string",
          "description": "주문 ID"
        },
        "customerId": {
          "type": "integer",
          "description": "고객 ID"
        },
        "amount": {
          "type": "integer",
          "minimum": 0,
          "description": "승인 금액"
        },
        "currency": {
          "type": "string",
          "description": "통화 코드",
          "examples": ["KRW", "USD"]
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time",
          "description": "결제 승인 시각. ISO-8601 UTC"
        }
      }
    }
  },
  "examples": [
    {
      "meta": {
        "eventId": "evt-pay-approved-001",
        "eventType": "PaymentApprovedEvent",
        "occurredAt": "2026-02-28T09:00:00Z"
      },
      "payload": {
        "paymentId": "pay-001",
        "orderId": "order-001",
        "customerId": 1001,
        "amount": 30000,
        "currency": "KRW",
        "approvedAt": "2026-02-28T09:00:00Z"
      }
    }
  ]
}
