{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "payment.initialized.v1",
  "title": "payment.initialized",
  "description": "결제 초기화 완료를 알리는 이벤트.",
  "type": "object",
  "required": ["meta", "payload"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "allOf": [
        {
          "$ref": "../common/event-meta.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "eventType": {
              "const": "PaymentInitializedEvent",
              "description": "이 이벤트의 고정 타입명"
            }
          }
        }
      ]
    },
    "payload": {
      "type": "object",
      "description": "비즈니스 데이터",
      "required": ["paymentId", "orderId", "requestedAt"],
      "additionalProperties": false,
      "properties": {
        "paymentId": {
          "type": "string",
          "description": "결제 ID"
        },
        "orderId": {
          "type": "string",
          "description": "주문 ID"
        },
        "requestedAt": {
          "type": "string",
          "format": "date-time",
          "description": "결제 초기화 시각. ISO-8601 UTC"
        }
      }
    }
  },
  "examples": [
    {
      "meta": {
        "eventId": "evt-pay-init-001",
        "eventType": "PaymentInitializedEvent",
        "occurredAt": "2026-02-28T09:00:00Z"
      },
      "payload": {
        "paymentId": "pay-001",
        "orderId": "order-001",
        "requestedAt": "2026-02-28T09:00:00Z"
      }
    }
  ]
}
